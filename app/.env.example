# Copy to .env.local and fill from your Firebase project settings.
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_FB_REGION=us-central1
# Standalone single-tenant deployments set the org id here:
VITE_ORG_ID=
# Public host for QR scan URLs (defaults to window origin):
VITE_APP_HOST=
