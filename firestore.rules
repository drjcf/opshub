rules_version = '2';

// OpsHub security rules v0.1
// Principles:
//  - Custom claims are the authorization source of truth.
//  - Finalized evidence is immutable. Period. Corrections go through
//    callables which create superseding versions via Admin SDK.
//  - auditLog is never client-writable.
//  - Surveyor access is read-only and time-boxed by claim.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function signedIn() { return request.auth != null; }

    function inOrg(orgId) {
      return signedIn() && request.auth.token.orgId == orgId;
    }

    function hasRole(orgId, role) {
      return inOrg(orgId) && role in request.auth.token.roles;
    }

    function isAdmin(orgId) {
      return hasRole(orgId, 'owner') || hasRole(orgId, 'admin');
    }

    function isHR(orgId) {
      return inOrg(orgId) && (
        'owner' in request.auth.token.roles ||
        'admin' in request.auth.token.roles ||
        'hr' in request.auth.token.roles ||
        'clinicalDirector' in request.auth.token.roles
      );
    }

    function isStaff(orgId) {
      return inOrg(orgId) && (
        'owner' in request.auth.token.roles ||
        'admin' in request.auth.token.roles ||
        'clinicalDirector' in request.auth.token.roles ||
        'staff' in request.auth.token.roles
      );
    }

    function isActiveSurveyor(orgId) {
      return inOrg(orgId)
        && 'surveyor' in request.auth.token.roles
        && request.auth.token.surveyorUntil is int
        && request.time < timestamp.value(request.auth.token.surveyorUntil);
    }

    function canRead(orgId) {
      return isStaff(orgId) || isActiveSurveyor(orgId);
    }

    // Fields the client may never set or alter directly.
    function untouched(fields) {
      return !request.resource.data.diff(resource.data)
        .affectedKeys().hasAny(fields);
    }

    // ---------- global reference data ----------
    match /standardsEditions/{editionId} {
      allow read: if signedIn();
      allow write: if false;                 // seeded by Admin SDK only
      match /standards/{standardId} {
        allow read: if signedIn();
        allow write: if false;
      }
    }

    // ---------- org tree ----------
    match /orgs/{orgId} {
      allow read: if canRead(orgId);
      allow write: if false;                 // org lifecycle via Admin SDK / callables

      // -- members: readable in-org; managed by callables
      match /members/{uid} {
        allow read: if isStaff(orgId);       // surveyors don't browse the roster
        allow write: if false;
      }

      // -- obligations: admins manage; everyone reads
      match /obligations/{obligationId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId);
        allow delete: if false;              // retire via status, never delete
      }

      // -- tasks: generated by scheduler; status transitions via callables only
      match /tasks/{taskId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // -- evidence: the crown jewels
      match /evidence/{evidenceId} {
        allow read: if canRead(orgId);

        // staff may create drafts only, attributed to themselves
        allow create: if isStaff(orgId)
          && request.resource.data.status == 'draft'
          && request.resource.data.createdBy.uid == request.auth.uid;

        // drafts editable by creator or admin; protected fields locked;
        // finalized/superseded docs are immutable
        allow update: if isStaff(orgId)
          && resource.data.status == 'draft'
          && request.resource.data.status == 'draft'
          && (resource.data.createdBy.uid == request.auth.uid || isAdmin(orgId))
          && untouched(['status','finalizedBy','finalizedAt',
                        'supersededBy','supersedes','createdBy','createdAt']);

        allow delete: if false;
      }

      // -- document control
      match /documents/{docId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId)
          && untouched(['currentVersionId']);   // pointer moves via callable
        allow delete: if false;

        match /versions/{versionId} {
          allow read: if canRead(orgId);
          allow create: if isAdmin(orgId)
            && request.resource.data.status == 'draft';
          allow update: if isAdmin(orgId)
            && resource.data.status == 'draft'
            && request.resource.data.status == 'draft';  // approval via callable
          allow delete: if false;
        }
      }

      // -- credentialing: admin/clinicalDirector write; staff read; surveyor read
      match /credentialFiles/{providerId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow delete: if false;
        match /items/{itemId} {
          allow read: if canRead(orgId);
          allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
          allow delete: if false;
        }
      }

      // -- personnel: staff details are NOT for surveyors beyond competency proof;
      //    keep read at staff level, expose competency summaries via evidence instead
      match /personnel/{staffId} {
        allow read: if isStaff(orgId);
        allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow delete: if false;

        match /trainingRecords/{recordId} {
          allow read: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector')
            || get(/databases/$(database)/documents/orgs/$(orgId)/personnel/$(staffId)).data.uid == request.auth.uid;
          allow write: if false;              // callables + triggers only
        }
        // Delta 10: HR documents — private. isHR OR the subject (own,
        // non-confidential). Never general staff, never surveyors.
        match /hrDocuments/{docId} {
          allow read: if isHR(orgId)
            || (inOrg(orgId)
                && get(/databases/$(database)/documents/orgs/$(orgId)/personnel/$(staffId)).data.uid == request.auth.uid
                && resource.data.confidential != true);
          allow write: if false;              // hrDoc callables only
        }
        match /{sub=**} {
          allow read: if isStaff(orgId);
          allow write: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        }
      }

      // -- QI studies
      match /qiStudies/{studyId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow delete: if false;
      }

      // -- committees & meetings
      match /committees/{committeeId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId);
        allow delete: if false;
        match /meetings/{meetingId} {
          allow read: if canRead(orgId);
          allow create, update: if isAdmin(orgId)
            && untouched(['minutesEvidenceId']); // minutes link set by callable
          allow delete: if false;
        }
      }

      // -- assets
      match /assets/{assetId} {
        allow read: if canRead(orgId);
        allow create, update: if isStaff(orgId);
        allow delete: if false;
      }

      // -- incidents: staff read/write; surveyors read (de-identified by schema)
      match /incidents/{incidentId} {
        allow read: if canRead(orgId);
        allow create: if isStaff(orgId);
        allow update: if (isAdmin(orgId) || hasRole(orgId, 'clinicalDirector'))
          && resource.data.status != 'closed';   // closed incidents immutable
        allow delete: if false;
      }


      // ===== Delta 01: checkpoints & templates =====
      match /checkpoints/{checkpointId} {
        allow read: if isStaff(orgId);        // tokens are semi-secret; no surveyors
        allow write: if false;                // minted/rotated via callables
      }
      match /checklistTemplates/{templateId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId);
        allow delete: if false;
      }

      // ===== Delta 02: registers & sweep ledger =====
      match /registers/{registerId} {
        allow read: if canRead(orgId);
        allow write: if false;                // registerCheck.submit only
      }
      match /sweepLedger/{key} {
        allow read: if isAdmin(orgId);
        allow write: if false;
      }
      match /notifications/{noteId} {
        allow read: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow write: if false;                // queued by functions only
      }

      // ===== Delta 03: training =====
      match /trainingRequirements/{reqId} {
        allow read: if canRead(orgId);
        allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow delete: if false;
      }

      // ===== Delta 04: embedded LMS =====
      match /courses/{courseId} {
        allow read: if isStaff(orgId) &&
          (resource.data.status == 'published' || isAdmin(orgId) ||
           hasRole(orgId, 'clinicalDirector'));
        allow create, update: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
        allow delete: if false;

        match /lessons/{lessonId} {
          allow read: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector');
          allow write: if (isAdmin(orgId) || hasRole(orgId, 'clinicalDirector'))
            && get(/databases/$(database)/documents/orgs/$(orgId)/courses/$(courseId)).data.status == 'draft';
        }
        match /answerKeys/{lessonId} {
          allow read, write: if false;        // callables only. Always.
        }
        match /versions/{v} {
          allow read: if isAdmin(orgId);      // contains answer keys
          allow write: if false;
        }
      }
      match /enrollments/{enrollmentId} {
        allow read: if isAdmin(orgId) || hasRole(orgId, 'clinicalDirector')
                    || resource.data.staffUid == request.auth.uid;
        allow write: if false;                // progress via callables
      }
      match /certificates/{certId} {
        allow read: if canRead(orgId);
        allow write: if false;
      }

      // ===== Delta 05: catalog =====
      match /catalogUpdates/{catalogId} {
        allow read: if isAdmin(orgId);
        allow write: if false;
      }

      // ===== Delta 06: licensee handbook (per-tenant, NOT surveyor-readable) =====
      match /handbookConfig/{cfg} {
        allow read: if isStaff(orgId);
        allow write: if false;                 // attestLicense callable only
      }
      match /handbookEntries/{standardId} {
        allow read: if isStaff(orgId);         // surveyors bring their own copy
        allow write: if false;                 // setEntry/ingest callables only
      }
      match /handbookEntriesDraft/{draftId} {
        allow read: if isStaff(orgId);         // review page reads staged parser output
        allow write: if false;                 // ingest/confirm callables only
      }

      // ===== Delta 09: document library (archive + folders) =====
      match /libraryFiles/{fileId} {
        allow read: if canRead(orgId);
        allow write: if false;                // callables only
      }
      match /folders/{folderId} {
        allow read: if canRead(orgId);
        allow write: if false;                // callables only
      }

      // ===== Delta 08: self-assessment scoring =====
      match /assessments/{aid} {
        allow read: if canRead(orgId);        // surveyors may see readiness
        allow write: if false;                // callables only
        match /ratings/{code} {
          allow read: if canRead(orgId);
          allow write: if false;              // rateItem/override callables only
        }
      }

      // -- audit log: read by admins and surveyors; written by Admin SDK only
      match /auditLog/{entryId} {
        allow read: if isAdmin(orgId) || isActiveSurveyor(orgId);
        allow write: if false;
      }
    }
  }
}
